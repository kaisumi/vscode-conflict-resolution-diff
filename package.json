{
  "name": "conflict-resolution-diff",
  "displayName": "conflict-resolution-diff",
  "description": "View conflict resolution diffs using AUTO_MERGE and --remerge-diff.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "conflict-resolution-diff.showUncommittedResolutionDiff",
        "title": "Conflict Resolution Diff: Show Uncommitted Resolution Diff"
      },
      {
        "command": "conflict-resolution-diff.showResolvedConflictDiff",
        "title": "Conflict Resolution Diff: Show Resolved Conflict Diff"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conflict-resolution-diff",
          "title": "Conflict Diff",
          "icon": "resources/conflict-diff.svg"
        }
      ]
    },
    "views": {
      "conflict-resolution-diff": [
        {
          "id": "conflict-resolution-diff.actions",
          "name": "Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "conflict-resolution-diff.actions",
        "contents": "Show conflict resolution diffs.\n\n[Show Uncommitted Resolution Diff](command:conflict-resolution-diff.showUncommittedResolutionDiff)\n[Show Resolved Conflict Diff](command:conflict-resolution-diff.showResolvedConflictDiff)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
