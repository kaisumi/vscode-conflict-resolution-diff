{
  "name": "conflict-resolution-diff",
  "displayName": "Conflict Resolution Diff",
  "description": "View Git conflict resolution diffs from Visual Studio Code.",
  "publisher": "kaisumi",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaisumi/vscode-conflict-resolution-diff.git"
  },
  "homepage": "https://github.com/kaisumi/vscode-conflict-resolution-diff#readme",
  "bugs": {
    "url": "https://github.com/kaisumi/vscode-conflict-resolution-diff/issues"
  },
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "git",
    "merge",
    "conflict",
    "diff",
    "remerge-diff"
  ],
  "preview": false,
  "activationEvents": [],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension runs Git commands in the current workspace to show conflict resolution diffs."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "conflict-resolution-diff.showUncommittedResolutionDiff",
        "title": "Conflict Resolution Diff: Show Uncommitted Resolution Diff"
      },
      {
        "command": "conflict-resolution-diff.showResolvedConflictDiff",
        "title": "Conflict Resolution Diff: Show Resolved Conflict Diff"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conflict-resolution-diff",
          "title": "Conflict Diff",
          "icon": "resources/conflict-diff.svg"
        }
      ]
    },
    "views": {
      "conflict-resolution-diff": [
        {
          "id": "conflict-resolution-diff.actions",
          "name": "Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "conflict-resolution-diff.actions",
        "contents": "Show conflict resolution diffs.\n\n[Show Uncommitted Resolution Diff](command:conflict-resolution-diff.showUncommittedResolutionDiff)\n[Show Resolved Conflict Diff from Commit SHA](command:conflict-resolution-diff.showResolvedConflictDiff)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
